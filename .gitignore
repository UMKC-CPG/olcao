share/
distrib/
=======
# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'
bin/

# Ignore directories that will contain install databases, binaries, and jobs
/share
/bin
/jobs

# Ignore directories that will contain compiled object files
/build/debug/*
/build/release/*

# Ignore any __pycache__ files (in the .olcao directory).
__pycache__

# RC files in .olcao/ are installed from src/scripts/ by "make install"
# and may be edited by the user after installation.  They must not be
# tracked here; the canonical versions live in src/scripts/.
.olcao/*rc.py

# ignore the external folder. This is a uniform place to put all the
# things external to OLCAO but are meant to be used with olcao.
/external
/external/*
